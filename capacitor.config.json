{
  "appId": "com.trombonecidadao.app",
  "appName": "Trombone Cidadão",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 3000,
      "showSpinner": false,
      "androidScaleType": "CENTER_INSIDE",
      "backgroundColor": "#4a2121"
    },
    "StatusBar": {
      "overlaysWebView": false
    },
    "Camera": {
      "enableZoom": true,
      "quality": 70,
      "allowEditing": false,
      "resultType": "uri"
    }
  },
  "ios": {
    "contentInset": "automatic"
  }
}
